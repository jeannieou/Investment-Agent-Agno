# LLM provider: openai | deepseek
LLM_PROVIDER=openai

# Required for OpenAI-backed agents in later stages
OPENAI_API_KEY=
OPENAI_WORKER_MODEL=gpt-4.1-mini
OPENAI_REASONING_MODEL=gpt-4.1

# Optional lower-cost provider
DEEPSEEK_API_KEY=
DEEPSEEK_WORKER_MODEL=deepseek-chat
DEEPSEEK_REASONING_MODEL=deepseek-reasoner

# Required once real web research tools are enabled
EXA_API_KEY=

# Optional backend debug output for AgentOS and CLI runs
AGNO_DEBUG=false
AGNO_DEBUG_LEVEL=1
